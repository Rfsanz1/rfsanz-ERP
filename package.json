{
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/frontend",
        "apps/backend",
        "packages/*"
    ],
    "scripts": {
        "dev": "pnpm --filter @erp-modern/frontend dev",
        "build": "pnpm --filter @erp-modern/frontend build && pnpm --filter gentong-mas-backend build",
        "start": "apps/backend/node_modules/.bin/prisma db push --accept-data-loss --schema=apps/backend/prisma/schema.prisma && node_modules/.bin/concurrently \"PORT=3000 node apps/backend/dist/main.js\" \"PORT=5000 pnpm --filter @erp-modern/frontend start\"",
        "backend:dev": "pnpm --filter gentong-mas-backend start:dev",
        "cap:sync": "pnpm --filter @erp-modern/frontend cap:sync",
        "build:android": "pnpm --filter @erp-modern/frontend build && pnpm --filter @erp-modern/frontend cap:sync",
        "build:ios": "pnpm --filter @erp-modern/frontend build && pnpm --filter @erp-modern/frontend build:ios"
    },
    "dependencies": {
        "concurrently": "^8.2.2",
        "pnpm": "^10.34.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "@scarf/scarf",
            "bcrypt",
            "esbuild",
            "prisma",
            "unrs-resolver"
        ]
    }
}
