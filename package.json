{
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/frontend",
        "apps/backend"
    ],
    "scripts": {
        "dev:backend": "pnpm --filter @erp-modern/backend start:dev",
        "dev:frontend": "pnpm --filter @erp-modern/frontend dev",
        "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
        "build:backend": "pnpm --filter @erp-modern/backend build",
        "build:frontend": "pnpm --filter @erp-modern/frontend build",
        "build:all": "pnpm build:backend && pnpm build:frontend"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "concurrently": "^8.2.2",
        "eventemitter3": "^5.0.4",
        "pnpm": "^10.34.1",
        "prisma": "^5.22.0",
        "tsx": "^4.22.4"
    }
}
