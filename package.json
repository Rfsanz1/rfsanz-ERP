{
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/frontend",
        "apps/backend"
    ],
    "scripts": {
        "dev:backend": "pnpm --filter @erp-modern/backend start:dev",
        "dev:frontend": "pnpm --filter @erp-modern/frontend dev",
        "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
        "build:backend": "pnpm --filter @erp-modern/backend build && cp -r apps/backend/src/docs apps/backend/dist/",
        "build:frontend": "pnpm --filter @erp-modern/frontend build",
        "build:all": "pnpm build:backend && pnpm build:frontend",
        "build": "pnpm build:backend && pnpm build:frontend",
        "start:backend": "PORT=6000 pnpm --filter @erp-modern/backend start",
        "start:frontend": "PORT=5000 pnpm --filter @erp-modern/frontend start",
        "start": "concurrently \"pnpm start:backend\" \"pnpm start:frontend\""
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "concurrently": "^8.2.2",
        "eventemitter3": "^5.0.4",
        "pnpm": "^10.34.1",
        "prisma": "^5.22.0",
        "tsx": "^4.22.4"
    }
}
