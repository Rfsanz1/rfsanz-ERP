{
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/frontend"
    ],
    "scripts": {
        "dev": "pnpm --filter @erp-modern/frontend dev",
        "build": "pnpm --filter @erp-modern/frontend build",
        "start": "pnpm --filter @erp-modern/frontend start",
        "cap:sync": "pnpm --filter @erp-modern/frontend cap:sync",
        "build:android": "pnpm build && pnpm --filter @erp-modern/frontend cap:sync",
        "build:ios": "pnpm build && pnpm --filter @erp-modern/frontend build:ios"
    },
    "dependencies": {
        "concurrently": "^8.2.2",
        "pnpm": "^10.34.1"
    }
}
