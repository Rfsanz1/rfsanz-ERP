modules = ["nodejs-20", "web", "bash", "nix"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @erp-modern/backend start:dev"
waitForPort = 6000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @erp-modern/frontend dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6000
externalPort = 6000

[userenv]

[userenv.shared]
BACKEND_URL = "http://localhost:6000"
PORT = "6000"
NODE_ENV = "development"
JWT_EXPIRES_IN = "7d"
RATE_LIMIT_MAX = "1000"
RATE_LIMIT_WINDOW_MS = "60000"
JWT_SECRET = "08c31aa22f714d84a88bc9169c8dba95f49f292daec1faf8f7c9bb78b9d87014c032469918688bd86bf1fa4499d035aa968e50ed375e9bf3a397613fdc090b8c"
JWT_REFRESH_SECRET = "91cd404b980363b7a0bb5823fb00dbfd5893fc31667f322f7ac641a0074de337fc8dbf0ca27239cfb9ecdc2696217f1bf13cd09b131972e7ac160cab6aa15e3a"
