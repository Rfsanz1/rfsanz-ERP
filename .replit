modules = ["nodejs-20", "web", "bash", "nix"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @erp-modern/frontend dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6000
externalPort = 6000

[[ports]]
localPort = 8000
externalPort = 8000

[userenv]

[userenv.shared]
BACKEND_URL = "https://ganti-dengan-url-backend-kamu.com"
NODE_ENV = "development"

[deployment]
deploymentTarget = "vm"
run = ["pnpm", "run", "start"]
build = ["pnpm", "run", "build"]
