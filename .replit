modules = ["nodejs-20", "web", "bash", "nix", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @erp-modern/backend start:dev"
waitForPort = 6000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @erp-modern/frontend dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6000
externalPort = 6000

[userenv]

[userenv.shared]
BACKEND_URL = "http://localhost:6000"
PORT = "6000"
NODE_ENV = "development"
JWT_EXPIRES_IN = "7d"
RATE_LIMIT_MAX = "1000"
RATE_LIMIT_WINDOW_MS = "60000"
JWT_SECRET = "m1x3auwWcvhssNDknT39Uoc1ra1GiufRsP8fB16fHvhx/MWqS0691TmimVFSmKL1gIyEjPqttP7p30SLJKNTbg=="
JWT_REFRESH_SECRET = "5m3LQtbwxUZjP4w5bP94UG3razCxclyr8mHcYjBdpynEDiFgF0rzDxcc3VgFOMbAjZviYR/5tM7FwDmqsTcOtQ=="
