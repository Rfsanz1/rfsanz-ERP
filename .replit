JWT_REFRESH_SECRET = "nL0M5iog1hiAq0uvSXKpEgQPW/3jBspPkU+9azL+JAR7KL8HbbDTC0JQx0LxJUhhI+yLUffmYx/oTPJUt0Gppw=="
JWT_EXPIRES_IN = "7d"
JWT_REFRESH_EXPIRES_IN = "30d"
FONNTE_GROUP_INVOICE = "120363405869453556@g.us"
FONNTE_GROUP_PAYMENT = "120363425112329389@g.us"
KLEDO_TOKEN = "kledo_pat_000Gfu_AAToiipPXKPSc0Pq8O2vKORuOsOLiRfOUVAqWb6f7WaXtSuzqk95yBt8J9XAOPKLxi0CYsdoszXm0YFN"

[deployment]
deploymentTarget = "vm"
run = ["pnpm", "run", "start"]
build = ["pnpm", "run", "build"]
