modules = ["nodejs-20", "web", "bash"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && pnpm --filter @erp-modern/frontend dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && apps/backend/node_modules/.bin/prisma db push --accept-data-loss --schema=apps/backend/prisma/schema.prisma && cd apps/backend && pnpm run start:dev"
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
NODE_ENV = "development"
BACKEND_URL = "http://localhost:3000"
PORT = "3000"
ADMIN_EMAIL = "admin@rfsanz.com"
ADMIN_NAME = "Administrator"
COMPANY_NAME = "Gentong Mas"
JWT_EXPIRES_IN = "7d"
JWT_REFRESH_EXPIRES_IN = "30d"
FONNTE_GROUP_INVOICE = "120363405869453556@g.us"
FONNTE_GROUP_PAYMENT = "120363425112329389@g.us"

[deployment]
deploymentTarget = "vm"
run = ["pnpm", "run", "start"]
build = ["pnpm", "run", "build"]
