modules = ["nodejs-20", "web", "bash", "nix", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @erp-modern/frontend dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/backend && pnpm exec prisma migrate deploy && pnpm run start:dev"
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 6000
externalPort = 6000

[userenv]

[userenv.shared]
NODE_ENV = "development"
BACKEND_URL = "http://localhost:3000"
PORT = "3000"
ADMIN_EMAIL = "admin@rfsanz.com"
ADMIN_PASSWORD = "root"
ADMIN_NAME = "Administrator"
COMPANY_NAME = "Gentong Mas"

[deployment]
deploymentTarget = "vm"
run = ["pnpm", "run", "start"]
build = ["pnpm", "run", "build"]
