# ============================================================
# RFSANZ ERP BACKEND — Environment Variables
# ============================================================
# Cara pakai:
#   cp .env.example .env
#   nano .env   ← ganti nilai yang perlu
# ============================================================
# CATATAN: Jika tidak membuat .env, docker-compose akan pakai
# nilai default yang sudah tertera di docker-compose.yml.
# Untuk PRODUCTION, wajib ganti JWT_SECRET & ADMIN_PASSWORD!
# ============================================================

# --- Server ---
PORT=6000
HOST_PORT=6000
NODE_ENV=production

# --- Database ---
# Diisi otomatis oleh docker-compose (pakai service 'db')
# Isi manual hanya jika pakai database eksternal:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# --- JWT (WAJIB diganti di production!) ---
JWT_SECRET=rfsanz-jwt-secret-change-me-in-production
JWT_REFRESH_SECRET=rfsanz-refresh-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# --- Admin Default ---
ADMIN_EMAIL=admin@rfsanz.com
ADMIN_PASSWORD=Admin@rfsanz123
ADMIN_NAME=Administrator

# --- Perusahaan ---
COMPANY_NAME=RFSANZ

# --- Rate Limiting ---
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# --- CORS (opsional, pisahkan dengan koma) ---
# CORS_ORIGINS=https://frontend-kamu.com

# --- Kledo Integration (opsional) ---
# KLEDO_TOKEN=token-kledo-kamu
# KLEDO_BASE_URL=https://api.kledo.com/api/v1
