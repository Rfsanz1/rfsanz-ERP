# ============================================================
# GENTONG MAS BACKEND — Environment Variables
# Salin file ini ke .env lalu isi nilai yang sesuai:
#   cp .env.example .env
# ============================================================

# --- Server ---
PORT=8000
NODE_ENV=production

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# --- JWT ---
JWT_SECRET=ganti-dengan-string-acak-yang-panjang-dan-aman
JWT_REFRESH_SECRET=ganti-dengan-string-acak-lain-yang-panjang
JWT_EXPIRES_IN=7d

# --- Admin Default ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
# Opsional: simpan password sebagai hash bcrypt (lebih aman)
# Generate: node -e "import('bcrypt').then(b=>b.hash('password',10).then(console.log))"
# ADMIN_PASSWORD_HASH=

# --- Perusahaan ---
ADMIN_NAME=Administrator
COMPANY_NAME=Gentong Mas

# --- Rate Limiting ---
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# --- CORS (opsional, pisahkan dengan koma) ---
# CORS_ORIGINS=https://frontend-kamu.com,https://app-lain.com

# --- Kledo Integration (opsional) ---
# KLEDO_TOKEN=token-kledo-kamu
# KLEDO_BASE_URL=https://api.kledo.com/api/v1
