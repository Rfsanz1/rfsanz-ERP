# ── Salin file ini menjadi .env dan isi nilainya ──
# cp .env.example .env

# ── Kledo Integration ──────────────────────────────────────
# Token API Kledo — dapatkan dari: Pengaturan > API > Personal Access Token
KLEDO_TOKEN=isi_token_kledo_anda_di_sini
KLEDO_BASE_URL=https://api.kledo.com/api/v1

# ── Admin Login ────────────────────────────────────────────
# Kredensial untuk login ke ERP
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
COMPANY_NAME=Gentong Mas

# Opsional: simpan password sebagai hash bcrypt (lebih aman)
# Generate dengan: node -e "const b=require('bcrypt'); b.hash('passwordbaru',10).then(console.log)"
# ADMIN_PASSWORD_HASH=

# ── JWT Secrets ────────────────────────────────────────────
JWT_SECRET=ganti-ini-dengan-string-acak-yang-panjang
JWT_REFRESH_SECRET=ganti-ini-dengan-string-acak-lain
JWT_EXPIRES_IN=24h

# ── Server ─────────────────────────────────────────────────
PORT=6000
NODE_ENV=production
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# ── CORS (opsional) ────────────────────────────────────────
# Tambahkan domain frontend jika berbeda server
# CORS_ORIGINS=https://erp.domainanda.com
