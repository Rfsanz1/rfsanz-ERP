  orgId        String           @default("default")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  shipments    TmsShipment[]
  lanes        TmsCustomerLane[]
}

model TmsCarrier {
  id                  String               @id @default(uuid())
  name                String
  mcNumber            String?
  dotNumber           String?
  scacCode            String?
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  address1            String?
  city                String?
  state               String?
  postalCode          String?
  country             String?
  validationTier      String               @default("unvalidated")
  registrationChecked Boolean              @default(false)
  insuranceVerified   Boolean              @default(false)
  identityConfirmed   Boolean              @default(false)
  complianceChecked   Boolean              @default(false)
  validationNotes     String?
  validatedAt         DateTime?
  archived            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  shipments           TmsShipment[]
  laneCarriers        TmsLaneCarrier[]
}

model TmsLocation {
  id                String          @id @default(uuid())
  name              String
  address1          String
  address2          String?
  city              String
  state             String?
  postalCode        String?
  country           String
  lat               Float?
  lng               Float?
  locationType      String?
  contactName       String?
  contactPhone      String?
  contactEmail      String?
  archived          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  shipmentsAsOrigin TmsShipment[]   @relation("TmsShipmentOrigin")
  shipmentsAsDest   TmsShipment[]   @relation("TmsShipmentDest")
  lanesAsOrigin     TmsLane[]       @relation("TmsLaneOrigin")
  lanesAsDest       TmsLane[]       @relation("TmsLaneDest")
  laneStops         TmsLaneStop[]
}

model TmsShipment {
  id                  String                @id @default(uuid())
  reference           String                @unique
  status              String                @default("draft")
  customerId          String?
  laneId              String?
  carrierId           String?
  originId            String?
  destinationId       String?
  pickupDate          DateTime?
  deliveryDate        DateTime?
  pickupWindowStart   DateTime?
  pickupWindowEnd     DateTime?
  deliveryWindowStart DateTime?
  deliveryWindowEnd   DateTime?
  proNumber           String?
  shipmentTypeId      String?
  archived            Boolean               @default(false)
  currentLat          Float?
  currentLng          Float?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  customer            TmsCustomer?          @relation(fields: [customerId], references: [id])
  carrier             TmsCarrier?           @relation(fields: [carrierId], references: [id])
  lane                TmsLane?              @relation(fields: [laneId], references: [id])
  origin              TmsLocation?          @relation("TmsShipmentOrigin", fields: [originId], references: [id])
  destination         TmsLocation?          @relation("TmsShipmentDest", fields: [destinationId], references: [id])
  events              TmsShipmentEvent[]
  items               TmsShipmentItem[]
  attachments         TmsAttachment[]
  comments            TmsComment[]
  telemetry           TmsSensorReading[]
  devices             TmsDeviceAssignment[]
}

