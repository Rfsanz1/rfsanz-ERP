  amount      Decimal           @db.Decimal(15, 2)
  deskripsi   String
  createdAt   DateTime          @default(now())
}

model BPJSConfig {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id])
  bpjsKesEmployee   Decimal  @default(1) @db.Decimal(5, 2)
  bpjsKesEmployer   Decimal  @default(4) @db.Decimal(5, 2)
  bpjsTKJHTEmployee Decimal  @default(2) @db.Decimal(5, 2)
  bpjsTKJHTEmployer Decimal  @default(3.7) @db.Decimal(5, 2)
  bpjsTKJKK         Decimal  @default(0.24) @db.Decimal(5, 2)
  bpjsTKJKM         Decimal  @default(0.3) @db.Decimal(5, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ==================== FIXED ASSET MANAGEMENT ====================

enum DepreciasiMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  SOLD
  UNDER_MAINTENANCE
}

model AssetCategory {
  id                    String       @id @default(cuid())
  tenantId              String
  tenant                Tenant       @relation(fields: [tenantId], references: [id])
  name                  String
  depreciationAccountId String? // akun Beban Penyusutan
  accDepAccountId       String? // akun Akumulasi Penyusutan
  defaultUsefulLife     Int          @default(60) // bulan
  defaultMethod         String       @default("straight_line")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  assets                FixedAsset[]
}

model FixedAsset {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Primary fields (new schema)
  code       String?        @unique
  name       String?
  categoryId String?
  category   AssetCategory? @relation(fields: [categoryId], references: [id])

  // Acquisition
  acquisitionDate  DateTime?
  acquisitionValue Decimal?  @db.Decimal(15, 2)

  // Depreciation
  usefulLifeMonths   Int? // umur manfaat dalam bulan
  depreciationMethod DepreciasiMethod @default(STRAIGHT_LINE)
  residualValue      Decimal          @default(0) @db.Decimal(15, 2)
  currentBookValue   Decimal?         @db.Decimal(15, 2) // nilai buku saat ini (calculated)

  // Details
  location       String?
  serialNumber   String?
  warrantyExpiry DateTime?
  vendor         String? // contactId atau nama vendor
  attachment     String? // URL foto/dokumen
  status         AssetStatus @default(ACTIVE)
  warehouseId    String?

  // Accounting
  accountAssetId      String?
  accountDepreciasiId String?
  accountAkumDepId    String?
  branchId            String?

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Legacy fields (backward compatibility)
  kode             String?           @unique
  nama             String?
  kategori         String?
  tanggalPerolehan DateTime?
  nilaiPerolehan   Decimal?          @db.Decimal(15, 2)
  nilaiResidu      Decimal?          @db.Decimal(15, 2)
  umurEkonomi      Int?
  metodeDepresiasi DepreciasiMethod? @default(STRAIGHT_LINE)

  depreciations AssetDepreciation[]
}

model AssetDepreciation {
  id              String     @id @default(uuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  assetId         String
  asset           FixedAsset @relation(fields: [assetId], references: [id])
  bulan           Int
  tahun           Int
  bebanDepresiasi Decimal    @db.Decimal(15, 2)
  akumDepresiasi  Decimal    @db.Decimal(15, 2)
  nilaiBuku       Decimal    @db.Decimal(15, 2)
  journalId       String?
  createdAt       DateTime   @default(now())

  @@unique([assetId, bulan, tahun])
}

