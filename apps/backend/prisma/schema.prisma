  id          String      @id @default(uuid())
  shipmentId  String
  shipment    TmsShipment @relation(fields: [shipmentId], references: [id])
  eventType   String
  description String?
  lat         Float?
  lng         Float?
  actorId     String?
  eventTime   DateTime    @default(now())
  createdAt   DateTime    @default(now())
}

model TmsShipmentItem {
  id          String      @id @default(uuid())
  shipmentId  String
  shipment    TmsShipment @relation(fields: [shipmentId], references: [id])
