datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// AUTH & USERS
model User {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  email       String
  password    String
  avatar      String?
  isActive    Boolean   @default(true)
  isOwner     Boolean   @default(false)
  invitedAt   DateTime?
  inviteToken String?   @unique
  inviteExpAt DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roleId             String?
  role               Role?                @relation(fields: [roleId], references: [id])
  AuditLog           AuditLog[]
  Order              Order[]
  SupplierRating     SupplierRating[]
  PasswordResetToken PasswordResetToken[]

  @@unique([tenantId, email])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]

  @@unique([tenantId, name])
}

model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  email       String?
  phone       String?
  address     String?
  logo        String?
  plan        String    @default("trial")
  trialEndsAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users                 User[]
  roles                 Role[]
  AuditLog              AuditLog[]
  AppSetting            AppSetting[]
  DriverArea            DriverArea[]
  Warehouse             Warehouse[]
  ProductCategory       ProductCategory[]
  ProductUnit           ProductUnit[]
  Product               Product[]
  StockMovement         StockMovement[]
  StockValuation        StockValuation[]
  StockLot              StockLot[]
  ProductWarehouseStock ProductWarehouseStock[]
  ProductVariant        ProductVariant[]
  ProductBundle         ProductBundle[]
  ProductTierPrice      ProductTierPrice[]
  UnitConversion        UnitConversion[]
  LandedCost            LandedCost[]
  LandedCostItem        LandedCostItem[]
  StockOpname           StockOpname[]
  StockOpnameItem       StockOpnameItem[]
  Customer              Customer[]
  Supplier              Supplier[]
  Order                 Order[]
  OrderItem             OrderItem[]
  Sale                  Sale[]
  SaleItem              SaleItem[]
  PurchaseOrder         PurchaseOrder[]
  PurchaseOrderItem     PurchaseOrderItem[]
  GoodsReceipt          GoodsReceipt[]
  GoodsReceiptItem      GoodsReceiptItem[]
  ChartOfAccount        ChartOfAccount[]
  JournalEntry          JournalEntry[]
  JournalEntryLine      JournalEntryLine[]
  BankAccount           BankAccount[]
  BankTransaction       BankTransaction[]
  CashTransaction       CashTransaction[]
  Employee              Employee[]
  Payroll               Payroll[]
  Attendance            Attendance[]
  KledoSyncLog          KledoSyncLog[]
  ShopeeOrder           ShopeeOrder[]
  Notification          Notification[]
  PosUser               PosUser[]
  PosCashierSession     PosCashierSession[]
  PosCategory           PosCategory[]
  PosProduct            PosProduct[]
  PosSale               PosSale[]
  PosSaleItem           PosSaleItem[]
  LoyaltyConfig         LoyaltyConfig[]
  CustomerLoyalty       CustomerLoyalty[]
  Lead                  Lead[]
  SalesTeam             SalesTeam[]
  CrmActivity           CrmActivity[]
  LostReason            LostReason[]
  Project               Project[]
  Task                  Task[]
  Milestone             Milestone[]
  Timesheet             Timesheet[]
  HelpdeskTeam          HelpdeskTeam[]
  HelpdeskTicket        HelpdeskTicket[]
  BillOfMaterial        BillOfMaterial[]
  BomComponent          BomComponent[]
  WorkCenter            WorkCenter[]
  ManufacturingOrder    ManufacturingOrder[]
  WorkOrder             WorkOrder[]
  LeaveType             LeaveType[]
  LeaveAllocation       LeaveAllocation[]
  LeaveRequest          LeaveRequest[]
  JobPosition           JobPosition[]
  JobApplication        JobApplication[]
  QualityControlPoint   QualityControlPoint[]
  QualityCheck          QualityCheck[]
  QualityAlert          QualityAlert[]
  Equipment             Equipment[]
  MaintenanceRequest    MaintenanceRequest[]
  Vehicle               Vehicle[]
  VehicleService        VehicleService[]
  RequestForQuotation   RequestForQuotation[]
  RfqItem               RfqItem[]
  VendorPricelist       VendorPricelist[]
  VendorBill            VendorBill[]
  VendorBillPayment     VendorBillPayment[]
  VendorBillItem        VendorBillItem[]
  PurchaseReturn        PurchaseReturn[]
  PurchaseReturnItem    PurchaseReturnItem[]
  SupplierRating        SupplierRating[]
  ReorderingRule        ReorderingRule[]
  LotSerial             LotSerial[]
  ScrapOrder            ScrapOrder[]
  Quotation             Quotation[]
  QuotationItem         QuotationItem[]
  Pricelist             Pricelist[]
  PricelistItem         PricelistItem[]
  Commission            Commission[]
  Tax                   Tax[]
  TaxLine               TaxLine[]
  EFaktur               EFaktur[]
  Account               Account[]
  JournalRecurring      JournalRecurring[]
  JournalRecurringLine  JournalRecurringLine[]
  Journal               Journal[]
  JournalLine           JournalLine[]
  FiscalYear            FiscalYear[]
  FiscalPeriod          FiscalPeriod[]
  PayrollComponent      PayrollComponent[]
  PayrollPeriod         PayrollPeriod[]
  PayrollSlip           PayrollSlip[]
  PayrollSlipLine       PayrollSlipLine[]
  BPJSConfig            BPJSConfig[]
  AssetCategory         AssetCategory[]
  FixedAsset            FixedAsset[]
  AssetDepreciation     AssetDepreciation[]
  Budget                Budget[]
  BudgetLine            BudgetLine[]
  Company               Company[]
  Branch                Branch[]
  PasswordResetToken    PasswordResetToken[]
  Invoice               Invoice[]
  InvoiceItem           InvoiceItem[]
  InvoicePayment        InvoicePayment[]
  CreditNote            CreditNote[]
  SalesReturn           SalesReturn[]
  SalesReturnItem       SalesReturnItem[]
  StockTransfer         StockTransfer[]
  StockTransferItem     StockTransferItem[]
  StockAdjustment       StockAdjustment[]
  StockAdjustmentItem   StockAdjustmentItem[]
  EmployeeContract      EmployeeContract[]
  WorkShift             WorkShift[]
  EmployeeMutasi        EmployeeMutasi[]
  BankReconciliation    BankReconciliation[]
  SmtpSetting           SmtpSetting[]
  DocumentNumberConfig  DocumentNumberConfig[]
  CompanyProfile        CompanyProfile[]
  Currency              Currency[]
  InvoiceTemplate       InvoiceTemplate[]
  WorkflowConfig        WorkflowConfig[]
  DefaultAccounts       DefaultAccounts[]
  NotificationConfig    NotificationConfig[]
  SalesQuotation        SalesQuotation[]
  SalesQuotationItem    SalesQuotationItem[]
  ReorderRule           ReorderRule[]
  Contact               Contact[]
  Expense               Expense[]
  InvoiceRecurring      InvoiceRecurring[]
  PaymentLink           PaymentLink[]
}

model Permission {
  id          String  @id @default(uuid())
  module      String
  action      String
  label       String
  description String?

  rolePerms RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  allowed      Boolean    @default(false)

  @@unique([roleId, permissionId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  resource  String
  metadata  Json?
  tableName String?
  recordId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  branchId  String?
  createdAt DateTime @default(now())
}

// MASTER DATA
model AppSetting {
  id        Int      @id @default(autoincrement())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DriverArea {
  id        Int      @id @default(autoincrement())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  areas     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id              String                  @id @default(uuid())
  tenantId        String
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  code            String                  @unique
  name            String
  address         String?
  active          Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  products        Product[]
  stockMovements  StockMovement[]
  purchaseOrders  PurchaseOrder[]
  warehouseStocks ProductWarehouseStock[]
}

model ProductCategory {
  id        String            @id @default(uuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  code      String            @unique
  name      String
  parentId  String?
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model ProductUnit {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String    @unique
  symbol    String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ==================== INVENTORY COSTING ENUMS ====================
enum CostingMethod {
  FIFO
  AVERAGE
  STANDARD
}

enum LandedCostSplitMethod {
  BY_QTY
  BY_VALUE
  BY_WEIGHT
}

// PRODUCT & INVENTORY
model Product {
  id                   String                  @id @default(uuid())
  tenantId             String
  tenant               Tenant                  @relation(fields: [tenantId], references: [id])
  sku                  String                  @unique
  name                 String
  brand                String?
  categoryId           String?
  category             ProductCategory?        @relation(fields: [categoryId], references: [id])
  unitId               String?
  unit                 ProductUnit?            @relation(fields: [unitId], references: [id])
  warehouseId          String?
  warehouse            Warehouse?              @relation(fields: [warehouseId], references: [id])
  hargaBeli            Decimal                 @default(0) @db.Decimal(15, 2)
  hargaJual            Decimal                 @default(0) @db.Decimal(15, 2)
  hargaKledo           Decimal                 @default(0) @db.Decimal(15, 2)
  stok                 Int                     @default(0)
  stokMinimum          Int                     @default(0)
  costingMethod        CostingMethod           @default(AVERAGE)
  standardCost         Decimal                 @default(0) @db.Decimal(15, 4)
  currentAvgCost       Decimal                 @default(0) @db.Decimal(15, 4)
  kledoProductId       String?
  isSpmBrand           Boolean                 @default(false)
  active               Boolean                 @default(true)
  description          String?
  imageUrl             String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  orderItems           OrderItem[]
  saleItems            SaleItem[]
  stockMovements       StockMovement[]
  stockOpnameItems     StockOpnameItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceiptItems    GoodsReceiptItem[]
  posProducts          PosProduct[]
  stockValuations      StockValuation[]
  stockLots            StockLot[]
  landedCostItems      LandedCostItem[]
  rfqItems             RfqItem[]
  vendorBillItems      VendorBillItem[]
  purchaseReturnItems  PurchaseReturnItem[]
  stockTransferItems   StockTransferItem[]
  stockAdjustmentItems StockAdjustmentItem[]
  salesQuotationItems  SalesQuotationItem[]
  reorderRules         ReorderRule[]
  warehouseStocks      ProductWarehouseStock[]
  variants             ProductVariant[]
  tierPrices           ProductTierPrice[]
  bundleParents        ProductBundle[]         @relation("BundleParent")
  bundleComponents     ProductBundle[]         @relation("BundleComponent")
}

model StockMovement {
  id          String     @id @default(uuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  type        String
  qty         Int
  note        String?
  referenceId String?
  createdAt   DateTime   @default(now())
}

model StockValuation {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  date         DateTime
  qty          Decimal  @db.Decimal(15, 4)
  unitCost     Decimal  @db.Decimal(15, 4)
  totalValue   Decimal  @db.Decimal(15, 2)
  movementType String
  referenceId  String?
  createdAt    DateTime @default(now())
}

model StockLot {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  nomorLot    String
  expiryDate  DateTime?
  qtyAwal     Decimal   @db.Decimal(15, 4)
  qtySisa     Decimal   @db.Decimal(15, 4)
  unitCost    Decimal   @db.Decimal(15, 4)
  referenceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, nomorLot])
}

model ProductWarehouseStock {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  qty         Decimal   @default(0) @db.Decimal(15, 4)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model ProductVariant {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  sku        String   @unique
  name       String
  attributes Json
  price      Decimal? @db.Decimal(15, 2)
  stock      Decimal  @default(0) @db.Decimal(15, 4)
  barcode    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductBundle {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product  @relation("BundleParent", fields: [productId], references: [id])
  componentId String
  component   Product  @relation("BundleComponent", fields: [componentId], references: [id])
  qty         Decimal  @db.Decimal(15, 4)
  createdAt   DateTime @default(now())
}

model ProductTierPrice {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  minQty    Decimal  @db.Decimal(15, 4)
  maxQty    Decimal? @db.Decimal(15, 4)
  price     Decimal  @db.Decimal(15, 2)
  currency  String   @default("IDR")
  createdAt DateTime @default(now())
}

model UnitConversion {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  fromUnit  String
  toUnit    String
  factor    Decimal  @db.Decimal(15, 8)
  createdAt DateTime @default(now())
}

model LandedCost {
  id          String                @id @default(uuid())
  tenantId    String
  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  purchaseId  String
  deskripsi   String
  amount      Decimal               @db.Decimal(15, 2)
  splitMethod LandedCostSplitMethod
  status      String                @default("draft")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  items       LandedCostItem[]
}

model LandedCostItem {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  landedCostId String
  landedCost   LandedCost @relation(fields: [landedCostId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  qty          Decimal    @db.Decimal(15, 4)
  alokasiBiaya Decimal    @db.Decimal(15, 2)
  createdAt    DateTime   @default(now())
}

model StockOpname {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  date        DateTime
  warehouseId String?
  status      String            @default("draft")
  note        String?
  items       StockOpnameItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model StockOpnameItem {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  stockOpnameId String
  stockOpname   StockOpname @relation(fields: [stockOpnameId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  stokSistem    Int
  stokFisik     Int
  selisih       Int
  note          String?
}

// CUSTOMERS & SUPPLIERS
model Customer {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  province        String?
  npwp            String?
  kledoId         String?          @unique
  creditLimit     Decimal          @default(0) @db.Decimal(15, 2)
  creditUsed      Decimal          @default(0) @db.Decimal(15, 2)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orders          Order[]
  sales           Sale[]
  invoices        Invoice[]
  salesReturns    SalesReturn[]
  salesQuotations SalesQuotation[]
}

model Supplier {
  id              String                @id @default(uuid())
  tenantId        String
  tenant          Tenant                @relation(fields: [tenantId], references: [id])
  code            String                @unique
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  npwp            String?
  bankName        String?
  bankAccount     String?
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  purchaseOrders  PurchaseOrder[]
  rfqs            RequestForQuotation[]
  pricelist       VendorPricelist[]
  vendorBills     VendorBill[]
  purchaseReturns PurchaseReturn[]
  ratings         SupplierRating[]
}

// SALES & ORDERS
model Order {
  id               Int         @id @default(autoincrement())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  namaCustomer     String
  noHp             String?
  alamat           String?
  catatan          String?
  salesName        String?
  userId           String?
  user             User?       @relation(fields: [userId], references: [id])
  customerId       String?
  customer         Customer?   @relation(fields: [customerId], references: [id])
  totalHarga       Decimal     @default(0) @db.Decimal(15, 2)
  status           String      @default("pending")
  statusPengiriman String?
  driverName       String?
  fotoPengiriman   String?
  lokasiToken      String?
  lokasiLat        String?
  lokasiLng        String?
  lokasiUpdatedAt  DateTime?
  kledoInvoiceId   String?     @unique
  kledoContactId   String?
  kledoSynced      Boolean     @default(false)
  tanggal          DateTime?
  metodePembayaran String?
  bankPilihan      String?
  pembayaranAwal   Decimal?    @db.Decimal(15, 2)
  items            Json        @default("[]")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  orderItems       OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  nama      String
  qty       Int
  harga     Decimal  @db.Decimal(15, 2)
  subtotal  Decimal  @db.Decimal(15, 2)
}

model Sale {
  id         String     @id @default(uuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  noFaktur   String     @unique
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  salesName  String?
  tanggal    DateTime
  totalHarga Decimal    @default(0) @db.Decimal(15, 2)
  diskon     Decimal    @default(0) @db.Decimal(15, 2)
  pajak      Decimal    @default(0) @db.Decimal(15, 2)
  grandTotal Decimal    @default(0) @db.Decimal(15, 2)
  status     String     @default("draft")
  kledoId    String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      SaleItem[]
}

model SaleItem {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  nama      String
  qty       Int
  harga     Decimal  @db.Decimal(15, 2)
  subtotal  Decimal  @db.Decimal(15, 2)
}

// PURCHASING
model PurchaseOrder {
  id              String              @id @default(uuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  noPo            String              @unique
  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?          @relation(fields: [warehouseId], references: [id])
  tanggal         DateTime
  tanggalKirim    DateTime?
  totalHarga      Decimal             @default(0) @db.Decimal(15, 2)
  status          String              @default("draft")
  note            String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  items           PurchaseOrderItem[]
  goodsReceipts   GoodsReceipt[]
  vendorBills     VendorBill[]
  purchaseReturns PurchaseReturn[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id])
  nama            String
  qty             Int
  hargaBeli       Decimal       @db.Decimal(15, 2)
  subtotal        Decimal       @db.Decimal(15, 2)
  qtyReceived     Int           @default(0)
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  noGr            String             @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  tanggal         DateTime
  status          String             @default("draft")
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  items           GoodsReceiptItem[]
  vendorBills     VendorBill[]
  purchaseReturns PurchaseReturn[]
}

model GoodsReceiptItem {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  goodsReceiptId String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  productId      String?
  product        Product?     @relation(fields: [productId], references: [id])
  nama           String
  qtyOrdered     Int
  qtyReceived    Int
  unitCost       Decimal      @default(0) @db.Decimal(15, 2)
  lotNumber      String?
  expiryDate     DateTime?
  note           String?
}

// FINANCE & ACCOUNTING
model ChartOfAccount {
  id               String             @id @default(uuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  code             String             @unique
  name             String
  type             String
  parentId         String?
  parent           ChartOfAccount?    @relation("CoaTree", fields: [parentId], references: [id])
  children         ChartOfAccount[]   @relation("CoaTree")
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
