  notes         String?
  status        String           @default("active")
  archived      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  origin        TmsLocation      @relation("TmsLaneOrigin", fields: [originId], references: [id])
  destination   TmsLocation      @relation("TmsLaneDest", fields: [destinationId], references: [id])
