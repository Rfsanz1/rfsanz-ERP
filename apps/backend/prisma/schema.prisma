// ==================== DOUBLE-ENTRY ACCOUNTING ====================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum FiscalStatus {
  OPEN
  CLOSED
}

model Account {
  id             String                 @id @default(uuid())
  tenantId       String
  tenant         Tenant                 @relation(fields: [tenantId], references: [id])
  code           String                 @unique
  name           String
  type           AccountType
  parentId       String?
  parent         Account?               @relation("AccountTree", fields: [parentId], references: [id])
  children       Account[]              @relation("AccountTree")
  description    String?
  isActive       Boolean                @default(true)
  openingBalance Decimal                @default(0) @db.Decimal(15, 2)
  normalBalance  String                 @default("DEBIT")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  journalLines   JournalLine[]
  recurringLines JournalRecurringLine[] @relation("AccountJournalRecurringLines")
  expenses       Expense[]
}

model JournalRecurring {
  id          String                 @id @default(uuid())
  tenantId    String
  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  frequency   String
  interval    Int                    @default(1)
  startDate   DateTime               @default(now())
  nextRunAt   DateTime
  endDate     DateTime?
  status      String                 @default("ACTIVE")
  journalId   String?
  journal     Journal?               @relation("JournalRecurringJournal", fields: [journalId], references: [id])
  createdById String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  lines       JournalRecurringLine[]
}

model JournalRecurringLine {
  id                 String           @id @default(uuid())
  tenantId           String
  tenant             Tenant           @relation(fields: [tenantId], references: [id])
  journalRecurringId String
  journalRecurring   JournalRecurring @relation(fields: [journalRecurringId], references: [id], onDelete: Cascade)
  accountId          String
  account            Account          @relation(fields: [accountId], references: [id], name: "AccountJournalRecurringLines")
  debit              Decimal          @default(0) @db.Decimal(15, 2)
  kredit             Decimal          @default(0) @db.Decimal(15, 2)
  deskripsi          String?
}

model Journal {
  id                String             @id @default(uuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  nomor             String             @unique
  tanggal           DateTime
  referensi         String?
  deskripsi         String?
  status            JournalStatus      @default(DRAFT)
  createdById       String?
  reversalOf        String?
  recurringJournals JournalRecurring[] @relation("JournalRecurringJournal")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lines             JournalLine[]
}

model JournalLine {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  journalId String
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  debit     Decimal  @default(0) @db.Decimal(15, 2)
  kredit    Decimal  @default(0) @db.Decimal(15, 2)
  deskripsi String?
  createdAt DateTime @default(now())
}

model FiscalYear {
  id        String         @id @default(uuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  nama      String
  startDate DateTime
  endDate   DateTime
  status    FiscalStatus   @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  periods   FiscalPeriod[]
}

model FiscalPeriod {
  id           String       @id @default(uuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  fiscalYearId String
  fiscalYear   FiscalYear   @relation(fields: [fiscalYearId], references: [id])
