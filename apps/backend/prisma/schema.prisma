  id                    String  @id @default(uuid())
  name                  String
  description           String?
  requiresPickupDate    Boolean @default(true)
  requiresDeliveryDate  Boolean @default(true)
}

model TmsLane {
  id            String           @id @default(uuid())
  name          String
  originId      String
  destinationId String
