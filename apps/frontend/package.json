{
  "name": "@erp-modern/frontend",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "start": "next start -p ${PORT:-5000}",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "cap:init": "cap init 'Gentong Mas ERP' com.gentongmas.erp --web-dir out",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "build:android": "next build && cap sync android",
    "build:ios": "next build && cap sync ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@gm/types": "workspace:*",
    "@gm/ui": "workspace:*",
    "@gm/utils": "workspace:*",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "axios": "^1.8.5",
    "clsx": "^2.1.1",
    "lucide-react": "^0.467.0",
    "next": "14.2.30",
    "next-pwa": "^5.6.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^1.14.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/forms": "^0.5.5",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.30",
    "eslint-config-prettier": "^9.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3"
  }
