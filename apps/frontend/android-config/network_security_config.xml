<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Network Security Config
  ────────────────────────────────
  Salin file ini ke: android/app/src/main/res/xml/network_security_config.xml
  setelah menjalankan `cap add android`.

  Tujuan: mengizinkan HTTP cleartext ke server ERP lokal (bukan HTTPS)
  sehingga APK bisa terhubung ke CasaOS di jaringan LAN.

  Referensi: https://developer.android.com/training/articles/security-config
-->
<network-security-config>
  <!-- Izinkan HTTP ke semua subnet jaringan lokal -->
  <domain-config cleartextTrafficPermitted="true">
    <!-- Subnet kelas C umum (192.168.x.x) -->
    <domain includeSubdomains="true">192.168.0.0</domain>
    <domain includeSubdomains="true">192.168.1.0</domain>
    <domain includeSubdomains="true">192.168.18.0</domain>
    <domain includeSubdomains="true">192.168.100.0</domain>

    <!-- Subnet kelas A (10.x.x.x) -->
    <domain includeSubdomains="true">10.0.0.0</domain>

    <!-- Subnet docker (172.x.x.x) -->
    <domain includeSubdomains="true">172.16.0.0</domain>
    <domain includeSubdomains="true">172.17.0.0</domain>

    <!-- localhost untuk development -->
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
  </domain-config>

  <!-- HTTPS tetap berlaku untuk domain publik -->
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
