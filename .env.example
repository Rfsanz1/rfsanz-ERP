# =====================================================================
# Gentong Mas ERP — Konfigurasi Lengkap
# Salin file ini: cp .env.example .env  lalu isi nilainya
# =====================================================================

# ─── Server ──────────────────────────────────────────────────────────
# IP server CasaOS di jaringan lokal (cek: ip addr show | grep "inet 192")
SERVER_IP=192.168.1.xxx

# Port yang di-expose ke host
FRONTEND_PORT=5000
BACKEND_PORT=3100

# ─── Database ─────────────────────────────────────────────────────────
# Password PostgreSQL (ganti dengan password yang aman)
POSTGRES_PASSWORD=erp_password_aman

# ─── JWT Secrets (WAJIB DIGANTI!) ─────────────────────────────────────
# Generate dengan: openssl rand -base64 64
JWT_SECRET=ganti-ini-dengan-string-random-panjang-dan-aman
JWT_REFRESH_SECRET=ganti-ini-juga-dengan-string-random-yang-berbeda
JWT_EXPIRES_IN=7d

# ─── Admin Default ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@rfsanz.com
ADMIN_PASSWORD=root
ADMIN_NAME=Administrator

# ─── Perusahaan ───────────────────────────────────────────────────────
COMPANY_NAME=Gentong Mas

# ─── CORS (opsional, pisahkan dengan koma jika lebih dari satu) ────────
# CORS_ORIGINS=http://192.168.1.xxx:5000,https://domain-kamu.com

# ─── Integrasi Kledo (opsional) ───────────────────────────────────────
# KLEDO_TOKEN=token-kledo-kamu
# KLEDO_BASE_URL=https://api.kledo.com/api/v1
