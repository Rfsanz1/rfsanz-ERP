# =====================================================================
# Gentong Mas ERP — Konfigurasi Environment Variables
# Salin file ini: cp .env.example .env  lalu isi semua nilainya
# =====================================================================

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────

# IP server CasaOS di jaringan lokal
# Cek dengan: ip addr show | grep "inet 192"
SERVER_IP=192.168.18.42

# URL publik backend (dipakai untuk link foto bukti TF di WA)
APP_URL=http://192.168.18.42:8000

# Mode environment (jangan diubah)
NODE_ENV=production

# Port backend (jangan diubah)
PORT=8000

# Port frontend yang di-expose ke host (default: 3000)
# Ganti jika port 3000 sudah dipakai aplikasi lain di CasaOS
FRONTEND_PORT=3000

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────

POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_password_aman_ganti_ini
POSTGRES_DB=gentong_mas_erp

# DATABASE_URL dibentuk otomatis oleh docker-compose dari variabel di atas.
# Jika menjalankan backend tanpa docker, isi manual:
# DATABASE_URL=postgresql://erp:erp_password_aman_ganti_ini@localhost:5432/gentong_mas_erp

# ─────────────────────────────────────────────
# JWT — Keamanan Login
# ─────────────────────────────────────────────
# WAJIB diganti sebelum deploy!
# Generate: openssl rand -base64 64

JWT_SECRET=ganti-dengan-string-random-panjang-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-dengan-string-refresh-random-berbeda-dari-jwt-secret

# Durasi token (opsional, default 7d)
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CORS — Akses Frontend
# ─────────────────────────────────────────────
# IP/domain yang diizinkan akses backend.
# Semua jaringan lokal (192.168.x.x, 10.x.x.x) sudah otomatis diizinkan.
# Isi ini hanya jika pakai domain/IP lain:
CORS_ORIGINS=

# ─────────────────────────────────────────────
# RATE LIMITING (opsional)
# ─────────────────────────────────────────────
# Batas request per IP (default: 100 req / 1 menit)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─────────────────────────────────────────────
# FONNTE — WhatsApp Gateway
# Daftar di: https://fonnte.com
# ─────────────────────────────────────────────

# Token API Fonnte
# Cara dapat: Login fonnte.com → Perangkat → klik nomor WA → salin Token
FONNTE_TOKEN=

# ── Grup Notifikasi Internal ──────────────────
# Format Group ID: angka@g.us  (contoh: 120363405869453556@g.us)
# Cara dapat Group ID:
#   1. Login fonnte.com
#   2. Klik Perangkat → pilih nomor WA kamu
#   3. Klik tab "Grup" → semua grup muncul beserta ID-nya
# CATATAN: Nomor HP yang scan QR Fonnte harus sudah JOIN ke grup tersebut

# Grup yang dapat notif setiap ORDER BARU masuk:
# Contoh pesan:
#   🛒 Order Baru Masuk!
#   📋 Invoice : #123
#   👤 Customer: BUDI 081234567890
#   💰 Total   : Rp 2.350.000
FONNTE_GROUP_INVOICE=

# Grup yang dapat notif setiap ada BUKTI TRANSFER diupload:
# Contoh pesan:
#   💸 Bukti Transfer Masuk
#   Order: #123
#   Customer: Budi - 081234567890
#   Total: Rp 2.350.000
#   Bank Tujuan: BRI
#   🖼️ Foto: http://192.168.18.42:6000/api/orders/123/bukti-tf
FONNTE_GROUP_BUKTI_TF=

# ─────────────────────────────────────────────
# KLEDO — Akuntansi Online (Opsional)
# Daftar di: https://kledo.com
# ─────────────────────────────────────────────

# Token API Kledo
# Cara dapat:
#   1. Login kledo.com
#   2. Klik nama akun (pojok kanan atas) → Pengaturan → API
#   3. Buat token baru → salin
KLEDO_TOKEN=

# URL API Kledo (jangan diubah kecuali ada instruksi khusus dari Kledo)
KLEDO_BASE_URL=https://api.kledo.com/api/v1
