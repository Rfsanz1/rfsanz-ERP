# =====================================================================
# Gentong Mas ERP — Frontend Only Configuration
# Salin file ini: cp .env.example .env  lalu isi nilainya
# =====================================================================

# URL backend kamu (ngrok atau IP server backend)
# Contoh ngrok  : https://briskly-underpaid-shucking.ngrok-free.dev
# Contoh lokal  : http://192.168.1.100:8000
BACKEND_URL=https://briskly-underpaid-shucking.ngrok-free.dev

# Port frontend yang di-expose ke host (default: 3000)
# Ganti jika port 3000 sudah dipakai aplikasi lain di CasaOS
FRONTEND_PORT=3000
