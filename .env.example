# =====================================================================
# Gentong Mas ERP — Konfigurasi
# Cara pakai: cp .env.example .env  lalu isi nilainya
# =====================================================================

# ─── Database ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=ganti_password_database_kamu

# ─── JWT Secrets (WAJIB DIGANTI!) ─────────────────────────────────────
# Generate dengan: openssl rand -base64 32
JWT_SECRET=ganti-ini-string-random-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-ini-juga-string-random-yang-berbeda
JWT_EXPIRES_IN=7d

# ─── Admin Default ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@rfsanz.com
ADMIN_PASSWORD=root
ADMIN_NAME=Administrator

# ─── Perusahaan ───────────────────────────────────────────────────────
COMPANY_NAME=Gentong Mas

# ─── Port ─────────────────────────────────────────────────────────────
FRONTEND_PORT=5000
BACKEND_PORT=3000

# ─── Integrasi Kledo (opsional) ───────────────────────────────────────
# KLEDO_TOKEN=token-kledo-kamu

# ─── Integrasi Fonnte/WhatsApp (opsional) ─────────────────────────────
# FONNTE_TOKEN=token-fonnte-kamu
# FONNTE_GROUP_INVOICE=id-grup-wa
# FONNTE_GROUP_BUKTI_TF=id-grup-wa

# ─── URL Aplikasi (opsional, untuk email notifikasi) ──────────────────
# APP_URL=https://domain-kamu.com

# ─── CORS (opsional, jika pakai domain custom) ────────────────────────
# CORS_ORIGINS=https://domain-kamu.com
